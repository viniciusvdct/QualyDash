   ============================================================ */
const fmtNum=n=>(n||0).toLocaleString('pt-BR',{maximumFractionDigits:0});
const fmtDec=(n,d=1)=>(n||0).toLocaleString('pt-BR',{maximumFractionDigits:d,minimumFractionDigits:d});
function fmtPPM(n){const d=CONFIG.decimais_ppm||0;return (n||0).toLocaleString('pt-BR',{maximumFractionDigits:d,minimumFractionDigits:d});}

function getMetaAjustada(){
  // meta é sempre PPM — o "período" apenas define como é mostrada ao usuário na interface.
  // Como PPM é adimensional por unidade produzida, a meta é a mesma independente do período escolhido.
  // O ajuste "por período" serve para comparar: PPM_ano vs meta, PPM_mes vs meta, PPM_dia vs meta
  // (todos em PPM, mas agrupamentos diferentes). Então só retorna a meta direto.
  return CONFIG.meta_ppm;
}

function parseDate(v){
  if(!v)return null;
  if(v instanceof Date)return v;
  if(typeof v==='number'){const d=XLSX.SSF.parse_date_code(v);if(d)return new Date(d.y,d.m-1,d.d);}
  if(typeof v==='string'){const m=v.match(/(\d{1,2})[\/\-\.](\d{1,2})[\/\-\.](\d{2,4})/);if(m){let y=parseInt(m[3]);if(y<100)y+=2000;return new Date(y,parseInt(m[2])-1,parseInt(m[1]));}}
  return null;
}

function showLoading(msg){document.getElementById('loadMsg').textContent=msg||"Processando…";document.getElementById('loading').classList.add('show');}
function hideLoading(){document.getElementById('loading').classList.remove('show');}
function toast(msg, err=false){
  const t=document.createElement('div');t.className='toast'+(err?' err':'');t.textContent=msg;
  document.body.appendChild(t);setTimeout(()=>t.remove(),3500);
}

/* ============================================================
   LEITURA DE ARQUIVOS
   ============================================================ */
async function readFile(file,kind){
  showLoading(`Lendo ${kind}…`);
  const data=await file.arrayBuffer();
  const wb=XLSX.read(data,{type:'array',cellDates:true});
  const ws=wb.Sheets[wb.SheetNames[0]];
  return XLSX.utils.sheet_to_json(ws,{defval:null,raw:true});
}

function processDefeitos(rows){
  return rows.map(r=>{
    const cli=String(r['Cliente']||'').replace(/^0+/,'');
    const mat=String(r['Material']||'').replace(/^0+/,'');
    const dtAbert=parseDate(r['Data da nota']);
    const dtFech=parseDate(r['Encerram.por data']);
    // Usa data de FECHAMENTO (conforme última decisão); se não tiver, cai para abertura
    const dt = dtFech || dtAbert;
    const cliData = CONFIG.clientes[cli];
    return {
      cliente:cli, material:mat, dano:r['Código do dano'], local:r['Code parte do objeto'],
      nota:r['Nota'], item:r['Item'],
      qInt:Number(r['Qtd.defeituosa interna'])||0,
      qExt:Number(r['Qtd.defeituosa externa'])||0,
      data:dt, dataAbert:dtAbert, dataFech:dtFech,
      ano:dt?dt.getFullYear():null, mes:dt?dt.getMonth()+1:null,
      consultor:(cliData?.consultor)||'Não mapeado',
      nomeCli:(cliData?.nome)||`[${cli}]`,
      diasFech:(dtAbert&&dtFech)?Math.round((dtFech-dtAbert)/86400000):null
    };
  }).filter(r=>r.data&&r.qInt>0);
}

function processProducao(rows){
  return rows.map(r=>{
    const mat=String(r['Material']||'').replace(/^0+/,'');
    const dt=parseDate(r['Data de lançamento']||r['Data do documento']);
    const tipo=String(r['Tipo de movimento']||'');
    const qtdKey=Object.keys(r).find(k=>k.toLowerCase().includes('qtd'));
    return {
      material:mat, qtd:Number(r[qtdKey])||0, data:dt, tipo:tipo,
      ano:dt?dt.getFullYear():null, mes:dt?dt.getMonth()+1:null
    };
  }).filter(r=>r.data&&(r.tipo==='131'||r.tipo==='132'));
}

async function loadDefeitosFile(file){
  try{
    state.fileDefRef = file;
    const rows=await readFile(file,'Defeitos');
    state.defeitos = processDefeitos(rows);
    document.getElementById('btnDef').classList.add('ok');
    document.getElementById('lblDef').textContent=`Defeitos: ${state.defeitos.length.toLocaleString('pt-BR')} reg.`;
    document.getElementById('rfDef').disabled = false;
    afterLoad();
  }catch(err){toast("Erro: "+err.message, true);}
  finally{hideLoading();}
}

async function loadProducaoFile(file){
  try{
    state.fileProdRef = file;
    const rows=await readFile(file,'Produção');
    state.producao = processProducao(rows);
    document.getElementById('btnProd').classList.add('ok');
    document.getElementById('lblProd').textContent=`Produção: ${state.producao.length.toLocaleString('pt-BR')} reg.`;
    document.getElementById('rfProd').disabled = false;
    afterLoad();
  }catch(err){toast("Erro: "+err.message, true);}
  finally{hideLoading();}
}

document.getElementById('fileDef').addEventListener('change', async e=>{
  const f=e.target.files[0]; if(!f) return; await loadDefeitosFile(f);
});
document.getElementById('fileProd').addEventListener('change', async e=>{
  const f=e.target.files[0]; if(!f) return; await loadProducaoFile(f);
});
document.getElementById('rfDef').addEventListener('click', ()=>document.getElementById('fileDef').click());
document.getElementById('rfProd').addEventListener('click', ()=>document.getElementById('fileProd').click());

function afterLoad(){
  if(state.defeitos&&state.producao){
    document.getElementById('empty').style.display='none';
    document.getElementById('filters').style.display='flex';
    populateFilters();
    renderAll();
  }
}

/* Reprocessa os dados já carregados (quando config muda) */
function reprocessData(){
  if(!state.fileDefRef || !state.fileProdRef) return;
  // só reprocessamos via nome de cliente/consultor — que usa o CONFIG
  state.defeitos.forEach(r=>{
    const c = CONFIG.clientes[r.cliente];
    r.consultor = c?.consultor || 'Não mapeado';
    r.nomeCli = c?.nome || `[${r.cliente}]`;
  });
}

