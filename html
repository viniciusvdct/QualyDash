        <div style="display:flex;gap:6px;margin-top:10px">
          <input id="newCliCod" placeholder="Código" style="flex:0 0 90px;padding:7px 10px;background:var(--panel2);border:1px solid var(--line);color:var(--ink);border-radius:5px">
          <input id="newCliNome" placeholder="Nome do cliente" style="flex:1.5;padding:7px 10px;background:var(--panel2);border:1px solid var(--line);color:var(--ink);border-radius:5px">
          <input id="newCliCons" placeholder="Consultor" style="flex:1.2;padding:7px 10px;background:var(--panel2);border:1px solid var(--line);color:var(--ink);border-radius:5px">
          <button class="btn" id="btnAddCli">+</button>
        </div>
      </div>

    </div>
  `;

  bindSettingsEvents();
}

function bindSettingsEvents(){
  // Meta
  document.getElementById('btnSaveMeta').addEventListener('click', ()=>{
    CONFIG.meta_ppm = parseFloat(document.getElementById('cfgMeta').value)||1541;
    CONFIG.meta_periodo = document.getElementById('cfgPeriodo').value;
    CONFIG.decimais_ppm = parseInt(document.getElementById('cfgDec').value)||0;
    toast('Meta atualizada');
    if(state.defeitos&&state.producao)renderAll();
  });

  // Export
  document.getElementById('btnExport').addEventListener('click', ()=>{
    const blob = new Blob([JSON.stringify(CONFIG, null, 2)], {type:'application/json'});
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = 'config.json';
    a.click(); URL.revokeObjectURL(url);
    toast('config.json exportado — coloque na pasta compartilhada');
  });

  // Import
  document.getElementById('fileImport').addEventListener('change', async e=>{
    const f = e.target.files[0]; if(!f) return;
    try{
      const txt = await f.text();
      const cfg = JSON.parse(txt);
      CONFIG = {...DEFAULT_CONFIG, ...cfg};
      if(state.defeitos) reprocessData();
      toast('Configurações importadas');
      renderSettings();
      if(state.defeitos&&state.producao){populateFilters();renderAll();}
    }catch(err){toast('Erro ao importar: '+err.message, true);}
  });

  // Reset
  document.getElementById('btnReset').addEventListener('click', ()=>{
    if(!confirm('Restaurar TODAS as configurações ao padrão?')) return;
    CONFIG = JSON.parse(JSON.stringify(DEFAULT_CONFIG));
    if(state.defeitos) reprocessData();
    toast('Configurações restauradas');
    renderSettings();
    if(state.defeitos&&state.producao){populateFilters();renderAll();}
  });

  // Clientes - inline edit
  document.getElementById('listCli').addEventListener('change', e=>{
    const input = e.target;
    if(!input.matches('input[data-f]')) return;
    const row = input.closest('.row');
    const cod = row.dataset.cli;
    const campo = input.dataset.f;
    if(!CONFIG.clientes[cod]) CONFIG.clientes[cod] = {nome:'',consultor:''};
    CONFIG.clientes[cod][campo] = input.value.trim();
    if(state.defeitos) reprocessData();
  });
  document.getElementById('listCli').addEventListener('click', e=>{
    if(!e.target.matches('.del-btn')) return;
    const cod = e.target.dataset.del;
    if(!confirm(`Remover cliente ${cod}?`)) return;
    delete CONFIG.clientes[cod];
    if(state.defeitos) reprocessData();
    renderSettings();
  });
  document.getElementById('btnAddCli').addEventListener('click', ()=>{
    const cod = document.getElementById('newCliCod').value.trim();
    const nome = document.getElementById('newCliNome').value.trim();
    const cons = document.getElementById('newCliCons').value.trim();
    if(!cod || !nome) return toast('Preencha código e nome', true);
    CONFIG.clientes[cod] = {nome, consultor:cons};
    if(state.defeitos) reprocessData();
    toast('Cliente adicionado');
    renderSettings();
  });
  // Busca cliente
  document.getElementById('searchCli').addEventListener('input', e=>{
    const q = e.target.value.toLowerCase();
    document.querySelectorAll('#listCli .row').forEach(r=>{
      const txt = r.textContent.toLowerCase();
      r.style.display = txt.includes(q)?'':'none';
    });
  });

  // Tipos
  document.getElementById('listTipos').addEventListener('change', e=>{
    if(!e.target.matches('input[data-f]')) return;
    const row = e.target.closest('.row');
    const cod = row.dataset.tipo;
    CONFIG.tipos_defeito[cod] = e.target.value.trim();
  });
  document.getElementById('listTipos').addEventListener('click', e=>{
    if(!e.target.matches('.del-btn')) return;
    const cod = e.target.dataset.del;
    if(!confirm(`Remover tipo ${cod}?`)) return;
    delete CONFIG.tipos_defeito[cod];
    renderSettings();
  });
  document.getElementById('btnAddTipo').addEventListener('click', ()=>{
    const cod = document.getElementById('newTipoCod').value.trim();
    const nome = document.getElementById('newTipoNome').value.trim();
    if(!cod || !nome) return toast('Preencha código e nome', true);
    CONFIG.tipos_defeito[cod] = nome;
    toast('Tipo adicionado');
    renderSettings();
  });
  document.getElementById('searchTipos').addEventListener('input', e=>{
    const q = e.target.value.toLowerCase();
    document.querySelectorAll('#listTipos .row').forEach(r=>{
      r.style.display = r.textContent.toLowerCase().includes(q)?'':'none';
    });
  });

  // Locais
  document.getElementById('listLocais').addEventListener('change', e=>{
    if(!e.target.matches('input[data-f]')) return;
    const row = e.target.closest('.row');
    const cod = row.dataset.local;
    CONFIG.locais_defeito[cod] = e.target.value.trim();
  });
  document.getElementById('listLocais').addEventListener('click', e=>{
    if(!e.target.matches('.del-btn')) return;
    const cod = e.target.dataset.del;
    if(!confirm(`Remover local ${cod}?`)) return;
    delete CONFIG.locais_defeito[cod];
    renderSettings();
  });
  document.getElementById('btnAddLocal').addEventListener('click', ()=>{
    const cod = document.getElementById('newLocalCod').value.trim();
    const nome = document.getElementById('newLocalNome').value.trim();
    if(!cod || !nome) return toast('Preencha código e nome', true);
    CONFIG.locais_defeito[cod] = nome;
    toast('Local adicionado');
    renderSettings();
  });
  document.getElementById('searchLocais').addEventListener('input', e=>{
    const q = e.target.value.toLowerCase();
    document.querySelectorAll('#listLocais .row').forEach(r=>{
      r.style.display = r.textContent.toLowerCase().includes(q)?'':'none';
    });
  });

  // Materiais
  document.querySelectorAll('[data-mat] input').forEach(inp=>{
    inp.addEventListener('change', e=>{
      const row = e.target.closest('[data-mat]');
      const cod = row.dataset.mat;
      const campo = e.target.dataset.f;
      if(!CONFIG.materiais[cod]) CONFIG.materiais[cod] = {nome:'',vasilhame:''};
      CONFIG.materiais[cod][campo] = e.target.value.trim();
    });
  });
  document.querySelectorAll('[data-mat] .del-btn').forEach(b=>{
    b.addEventListener('click', ()=>{
      const cod = b.dataset.del;
      if(!confirm(`Remover material ${cod}?`)) return;
      delete CONFIG.materiais[cod];
      renderSettings();
    });
  });
  document.getElementById('btnAddMat').addEventListener('click', ()=>{
    const cod = document.getElementById('newMatCod').value.trim();
    const nome = document.getElementById('newMatNome').value.trim();
    const vas = document.getElementById('newMatVas').value.trim();
    if(!cod) return toast('Preencha o código', true);
    CONFIG.materiais[cod] = {nome, vasilhame:vas};
    toast('Material adicionado');
    renderSettings();
  });
}

/* ============================================================
   CARREGAMENTO AUTOMÁTICO DE config.json
   ============================================================ */
(async function tryAutoLoadConfig(){
  try{
    const res = await fetch('config.json',{cache:'no-cache'});
    if(res.ok){
      const cfg = await res.json();
      CONFIG = {...DEFAULT_CONFIG, ...cfg};
      console.log('config.json carregado automaticamente');
      toast('config.json carregado da pasta');
    }
  }catch(e){/* arquivo não existe ou CORS — sem problema, usa o padrão */}
})();
</script>
