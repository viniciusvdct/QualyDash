   ============================================================ */
function renderTypes(){
  const def=applyFilters(state.defeitos);

  // COMBINADO em destaque no topo
  const aComb=aggSum(def, r=>`${r.dano}||${r.local}`, r=>r.qInt);
  const combArr=[...aComb.entries()].map(([k,v])=>{
    const [d,l]=k.split('||');
    return {d,l,v,dNome:CONFIG.tipos_defeito[d]||d,lNome:CONFIG.locais_defeito[l]||l};
  }).sort((a,b)=>b.v-a.v);
  const totalComb=combArr.reduce((s,r)=>s+r.v,0);

  const aT=aggSum(def,r=>r.dano,r=>r.qInt);
  const tipos=[...aT.entries()].map(([k,v])=>({k,nome:CONFIG.tipos_defeito[k]||k,v})).sort((a,b)=>b.v-a.v);
  const aL=aggSum(def,r=>r.local,r=>r.qInt);
  const locais=[...aL.entries()].map(([k,v])=>({k,nome:CONFIG.locais_defeito[k]||k,v})).sort((a,b)=>b.v-a.v);

  document.getElementById('page-types').innerHTML=`
    <div class="card featured">
      <h3>★ Combinação Tipo + Local</h3>
      <div class="desc">Análise cruzada — defeito de um tipo específico em um local específico (${combArr.length} combinações distintas)</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
        <div style="height:420px;position:relative"><canvas id="cTipComb"></canvas></div>
        <div class="scroll-y" style="max-height:420px"><table class="data"><thead><tr><th>Tipo</th><th>Local</th><th>Defeitos</th><th>%</th></tr></thead><tbody>
        ${combArr.slice(0,50).map(r=>`<tr><td><code>${r.d}</code> · ${r.dNome}</td><td><code>${r.l}</code> · ${r.lNome}</td><td class="num"><b>${fmtNum(r.v)}</b></td><td class="num">${fmtDec(totalComb?r.v/totalComb*100:0,1)}%</td></tr>`).join('')}
        </tbody></table></div>
      </div>
    </div>

    <div class="grid grid-2">
      <div class="card tall"><h3>Ranking · Tipos de Defeito</h3><div class="desc">${tipos.length} tipos identificados</div><div class="canvas-wrap"><canvas id="cTipTipos"></canvas></div></div>
      <div class="card tall"><h3>Ranking · Locais do Defeito</h3><div class="desc">${locais.length} locais identificados</div><div class="canvas-wrap"><canvas id="cTipLocais"></canvas></div></div>
    </div>

    <div class="card"><h3>Matriz · Tipo × Local (heatmap)</h3>
      <div class="desc">Cruzamento dos top 10 tipos com top 8 locais</div>
      <div id="matriz" style="overflow-x:auto"></div>
    </div>

    <div class="grid grid-2">
      <div class="card"><h3>Todos os Tipos</h3>
        <div class="scroll-y"><table class="data"><thead><tr><th>Cód.</th><th>Tipo</th><th>Defeitos</th><th>%</th></tr></thead><tbody>
        ${tipos.map(r=>{const tot=tipos.reduce((s,x)=>s+x.v,0);return`<tr><td><code>${r.k}</code></td><td>${r.nome}</td><td class="num">${fmtNum(r.v)}</td><td class="num">${fmtDec(tot?r.v/tot*100:0,1)}%</td></tr>`}).join('')}
        </tbody></table></div></div>
      <div class="card"><h3>Todos os Locais</h3>
        <div class="scroll-y"><table class="data"><thead><tr><th>Cód.</th><th>Local</th><th>Defeitos</th><th>%</th></tr></thead><tbody>
        ${locais.map(r=>{const tot=locais.reduce((s,x)=>s+x.v,0);return`<tr><td><code>${r.k}</code></td><td>${r.nome}</td><td class="num">${fmtNum(r.v)}</td><td class="num">${fmtDec(tot?r.v/tot*100:0,1)}%</td></tr>`}).join('')}
        </tbody></table></div></div>
    </div>`;

  // combinado gráfico top 15
  makeChart('cTipComb',{type:'bar',data:{labels:combArr.slice(0,15).map(r=>`${r.d}×${r.l}`),datasets:[{data:combArr.slice(0,15).map(r=>r.v),backgroundColor:'#ff5b3a',borderRadius:3}]},options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{title:c=>{const r=combArr[c[0].dataIndex];return `${r.d}·${r.dNome}\n${r.l}·${r.lNome}`;},label:c=>`${fmtNum(c.parsed.x)} defeitos`}}}}});

  makeChart('cTipTipos',{type:'bar',data:{labels:tipos.slice(0,15).map(r=>`${r.k} · ${r.nome.substring(0,22)}`),datasets:[{data:tipos.slice(0,15).map(r=>r.v),backgroundColor:'#ff5b3a',borderRadius:3}]},options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}}}});
  makeChart('cTipLocais',{type:'bar',data:{labels:locais.slice(0,15).map(r=>`${r.k} · ${r.nome.substring(0,22)}`),datasets:[{data:locais.slice(0,15).map(r=>r.v),backgroundColor:'#b07cff',borderRadius:3}]},options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}}}});

  // matriz heatmap
  {const topT=tipos.slice(0,10),topL=locais.slice(0,8);
