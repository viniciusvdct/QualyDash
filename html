/* ============================================================
   06 · TENDÊNCIAS
   ============================================================ */
function renderTrends(){
  const def=applyFilters(state.defeitos),prod=applyFilters(state.producao,true);
  const meta = getMetaAjustada();
  const aMes=aggSum(def,r=>`${r.ano}-${String(r.mes).padStart(2,'0')}`,r=>r.qInt);
  const aMesP=aggSum(prod,r=>`${r.ano}-${String(r.mes).padStart(2,'0')}`,r=>r.qtd);
  const keys=[...new Set([...aMes.keys(),...aMesP.keys()])].sort();
  const ppmM=keys.map(k=>ppm(aMes.get(k)||0,aMesP.get(k)||0));
  const mov3=ppmM.map((_,i)=>{const start=Math.max(0,i-2);const slice=ppmM.slice(start,i+1);return slice.reduce((a,b)=>a+b,0)/slice.length;});
  const aAno=aggSum(def,r=>r.ano,r=>r.qInt);
  const aAnoP=aggSum(prod,r=>r.ano,r=>r.qtd);
  const anos=[...new Set([...aAno.keys(),...aAnoP.keys()])].sort();
  const ppmAno=anos.map(a=>ppm(aAno.get(a)||0,aAnoP.get(a)||0));
  const topTipos=[...aggSum(def,r=>r.dano,r=>r.qInt).entries()].sort((a,b)=>b[1]-a[1]).slice(0,5).map(r=>r[0]);

  document.getElementById('page-trends').innerHTML=`
    <div class="grid grid-2">
      <div class="card tall"><h3>PPM Mensal · média móvel 3M</h3><div class="desc">Linha clara = mês · Linha forte = tendência</div><div class="canvas-wrap"><canvas id="cTrPPMmm"></canvas></div></div>
      <div class="card tall"><h3>Variação YoY · PPM</h3><div class="desc">Ano vs. ano (%)</div><div class="canvas-wrap"><canvas id="cTrYoY"></canvas></div></div>
    </div>
    <div class="grid grid-2">
      <div class="card tall"><h3>Tendência dos 5 Principais Tipos</h3><div class="desc">Evolução mensal</div><div class="canvas-wrap"><canvas id="cTrTipos"></canvas></div></div>
      <div class="card tall"><h3>Defeitos Acumulados</h3><div class="desc">Curva acumulada</div><div class="canvas-wrap"><canvas id="cTrAcc"></canvas></div></div>
    </div>`;

  makeChart('cTrPPMmm',{type:'line',data:{labels:keys,datasets:[{label:'PPM mensal',data:ppmM,borderColor:'rgba(108,182,255,.4)',backgroundColor:'transparent',tension:.2,pointRadius:0,borderWidth:1.5},{label:'Média móvel 3M',data:mov3,borderColor:'#ff5b3a',tension:.3,pointRadius:0,borderWidth:2.5},{label:`Meta ${fmtPPM(meta)}`,data:keys.map(()=>meta),borderColor:'#ffd166',borderDash:[6,4],borderWidth:2,pointRadius:0}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'bottom'}},scales:{y:{beginAtZero:true,ticks:{callback:v=>fmtPPM(v)}}}}});

  {const variacao=ppmAno.map((v,i)=>i===0?0:(ppmAno[i-1]>0?(v-ppmAno[i-1])/ppmAno[i-1]*100:0));
   makeChart('cTrYoY',{type:'bar',data:{labels:anos,datasets:[{data:variacao,backgroundColor:variacao.map(v=>v<=0?'#3ddc97':'#ff5b6e'),borderRadius:4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>`${fmtDec(c.parsed.y,1)}%`}}},scales:{y:{ticks:{callback:v=>v+'%'}}}}});}

  {const datasets=topTipos.map((t,i)=>{const d=aggSum(def.filter(r=>r.dano===t),r=>`${r.ano}-${String(r.mes).padStart(2,'0')}`,r=>r.qInt);return{label:`${t}·${(CONFIG.tipos_defeito[t]||t).substring(0,16)}`,data:keys.map(k=>d.get(k)||0),borderColor:COLORS[i],backgroundColor:COLORS[i]+'22',tension:.25,pointRadius:0,fill:false};});
   makeChart('cTrTipos',{type:'line',data:{labels:keys,datasets},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'bottom',labels:{boxWidth:10,font:{size:10}}}}}});}

  {let acc=0;const data=keys.map(k=>{acc+=aMes.get(k)||0;return acc;});
   makeChart('cTrAcc',{type:'line',data:{labels:keys,datasets:[{label:'Defeitos acumulados',data,borderColor:'#b07cff',backgroundColor:'rgba(176,124,255,.15)',tension:.2,fill:true,pointRadius:0}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}}}});}
}

